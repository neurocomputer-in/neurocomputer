{
  "name": "neuro-web",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "desktop": "electron --no-sandbox .",
    "desktop:dev": "FRONTEND_PORT=3002 electron --no-sandbox .",
    "build:desktop": "next build && electron-builder",
    "pack:desktop": "next build && electron-builder --dir"
  },
  "dependencies": {
    "@chakra-ui/react": "^2.8.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@reduxjs/toolkit": "^2.2.3",
    "@types/three": "^0.183.1",
    "@use-gesture/react": "^10.3.1",
    "axios": "^1.6.8",
    "framer-motion": "^11.1.7",
    "livekit-client": "^2.5.7",
    "lucide-react": "^1.8.0",
    "next": "14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-redux": "^9.1.1",
    "react-syntax-highlighter": "^15.5.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "three": "^0.183.2",
    "vaul": "^1.1.2",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "xterm-addon-webgl": "^0.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.4.19",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.38",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5"
  },
  "build": {
    "appId": "com.neuro.desktop",
    "productName": "Neuro",
    "files": [
      "electron/**/*",
      ".next/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json",
      "next.config.js"
    ],
    "extraResources": [
      {
        "from": "../server.py",
        "to": "backend/server.py"
      },
      {
        "from": "../core",
        "to": "backend/core"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "electron/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "icon": "electron/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/icon.png"
    }
  }
}
